# LLM 配置
# 提供商: openai 或 anthropic
VITE_LLM_PROVIDER=anthropic

# API 基础 URL (可选，留空使用默认值)
# OpenAI 默认: https://api.openai.com/v1
# Anthropic 默认: https://api.anthropic.com/v1
VITE_LLM_BASE_URL=https://api.anthropic.com/v1

# API 密钥 (必填)
VITE_LLM_API_KEY=sk-anthropic

# 模型 ID (可选，留空使用默认值)
# OpenAI 默认: gpt-4o-mini
# Anthropic 默认: claude-sonnet-4-20250514
VITE_LLM_MODEL=claude-sonnet-4-20250514
