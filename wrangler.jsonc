{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "imarticle",
	"main": "./src/worker.js",
	"compatibility_date": "2025-09-27",
	"observability": {
		"enabled": true
	},
	"assets": {
		"directory": "./dist/client",
		"binding": "ASSETS",
		"not_found_handling": "single-page-application"
	},
	"compatibility_flags": [
		"nodejs_compat"
	],
	"kv_namespaces": [
		{
			"binding": "USAGE_KV",
			"id": "32c104e1339b42309dd9ecd84ab10856"
		}
	]
}